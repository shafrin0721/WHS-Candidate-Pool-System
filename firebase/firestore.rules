rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Candidates collection - main talent pool
    match /candidates/{candidateId} {
      allow read: if true;  // Anyone can read (or add auth condition)
      allow create: if request.auth != null;  // Authenticated users can create
      allow update: if request.auth != null && 
        (request.resource.data.email == resource.data.email || 
         request.auth.uid == resource.data.userId);
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    // Users collection - for admin access
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Applications/Jobs collection
    match /applications/{applicationId} {
      allow read: if true;
      allow create, update: if request.auth != null;
    }
    
    // Analytics/Dashboard metrics (auto-updated by Cloud Functions)
    match /analytics/{metricId} {
      allow read: if true;
      allow write: if false;  // Only Cloud Functions can write
    }
    
    // Duplicate tracking (for merge/update operations)
    match /duplicates/{duplicateId} {
      allow read, write: if request.auth != null;
    }
  }
}