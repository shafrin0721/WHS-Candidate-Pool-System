rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // CV/Resume files
    match /cvs/{candidateId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && 
        (request.resource.size < 5 * 1024 * 1024);  // Max 5MB
      
      // Only allow PDF, DOCX, DOC files
      allow create: if request.auth != null &&
        request.resource.contentType.matches('application/pdf|application/vnd.openxmlformats-officedocument.wordprocessingml.document|application/msword');
    }
    
    // Profile photos
    match /profiles/{candidateId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null &&
        request.resource.size < 2 * 1024 * 1024;  // Max 2MB
      
      allow create: if request.resource.contentType.matches('image/jpeg|image/png|image/jpg');
    }
    
    // System files (temp uploads, backups)
    match /system/{filePath=**} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }
  }
}